{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "mcp": {

  },
  "plugin": [
    "opencode-gpt-imagegen",
    "oh-my-opencode-slim",
    "@franlol/opencode-md-table-formatter@latest",
    "@gotgenes/opencode-agent-identity",
    "opencode-vibeguard",
    "@cortexkit/opencode-magic-context@latest",
    "@cortexkit/aft-opencode@latest"
  ],
  "instructions": [
    "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "compaction": {
    "prune": false,
    "auto": false
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".venv/**",
      "venv/**",
      ".pytest_cache/**",
      "build/**",
      "venv/**",
      ".vscode/**",
      ".idea/**",
      ".ruff_cache/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".cache/**",
      "target/**",
      "out/**",
      "bin/**",
      "obj/**"
    ]
  },
  "experimental": {
    "mcp_timeout": 120000,
    "batch_tool": true,
    "continue_loop_on_deny": true
  }
}
