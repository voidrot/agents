{
  "$schema": "https://raw.githubusercontent.com/cortexkit/magic-context/master/assets/magic-context.schema.json",
  "cache_ttl": "5m",
  "language": "en",
   "sqlite": {
    "cache_size_mb": 512,   // default: 64, min: 2, max: 2048 — page-cache size per connection
    "mmap_size_mb": 1024    // default: 0 (disabled), min: 0, max: 8192 — memory-mapped I/O size
  },
  "temporal_awareness": true,
  "auto_update": true,
  "historian": {
    "model": "openai/gpt-5.5",
    "variant": "medium"
  },
  "dreamer": {
    "model": "openai/gpt-5.4",
    "variant": "medium",
    "tasks": {
      "map-memories": { "schedule": "0 2 * * *" },
      "verify": { "schedule": "0 3 * * *" },
      "verify-broad": { "schedule": "0 4 * * 0" },
      "curate": { "schedule": "0 4 * * 0" },
      "classify-memories": { "schedule": "0 6 * * *" },
      "retrospective": { "schedule": "0 5 * * *" },
      "maintain-docs": { "schedule": "0 0 * * *" },
      "promote-primers": { "schedule": "0 3 * * *", "promotion_threshold": 2 },
      "refresh-primers": { "schedule": "0 3 * * *" },
      "evaluate-smart-notes": { "schedule": "0 3 * * *" },
      "review-user-memories": { "schedule": "0 3 * * *", "promotion_threshold": 3 }
    }
  },
  "sidekick": {
    "model": "openai/gpt-5.4-mini",
    "variant": "low"
  },
  "embedding": {
    "provider": "local"
  },
  "memory": {
    "enabled": true,
    "injection_budget_tokens": 4000,
    "auto_promote": true,
    "retrieval_count_promotion_threshold": 3,
    "auto_search": {
      "enabled": true,
      "score_threshold": 0.6,
      "min_prompt_chars": 20
    },
    "git_commit_indexing": {
      "enabled": true,
      "since_days": 365,
      "max_commits": 2000
    }
  }
}
